{
  "name": "@proofcomputer/switchboard-express",
  "version": "0.1.0",
  "description": "Express adapter for Switchboard Acurast webserver jobs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@proofcomputer/switchboard-sdk": "github:proof-computer/switchboard-sdk#main"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "express": "^5.2.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@proofcomputer/switchboard-sdk"
    ]
  },
  "engines": {
    "node": ">=20"
  },
